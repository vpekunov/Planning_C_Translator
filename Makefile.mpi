.SUFFIXES:

SRC_DIR := ./Examples/MPI2REENT.dir
LDFLAGS := -lm -lpthread
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
COMPILER := $(shell ls /opt/homebrew/bin/g++*)
else
COMPILER := g++
endif
CPPFLAGS := -fopenmp -fgnu-tm -fpermissive -O4 -std=c++11 -I/opt/homebrew/include

SRCS=$(wildcard $(SRC_DIR)/*.cpp)

CCS=$(SRCS:.cpp=.cc)

MPIS==$(SRCS:.cpp=.mpi)

EXES=$(SRCS:.cpp=)

all: $(EXES)

%: %.cc
	$(COMPILER) $(CPPFLAGS) -o $@ -I../../ $< $(LDFLAGS)

%.cc: %.mpi
	./Reenterable -strict-pre-checks -strict-plc-checks $< $@

%.mpi: %.cpp
	./mpi2reent `head -n 1 $< | cut -c 3-5` $< $@

clean:
	rm -rf $(CCS)
	rm -rf $(MPIS)
	rm -rf $(EXES)
