.SUFFIXES:

SRC_DIR := ./Examples/Vectorized
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
COMPILER := $(shell ls /opt/homebrew/bin/g++*)
CPPFLAGS := -fopenmp -fgnu-tm -fpermissive -O4 -std=c++11
LDFLAGS := -lm -lpthread -framework OpenCL
else
COMPILER := g++
CPPFLAGS := -fopenmp -fgnu-tm -fpermissive -O4 -std=c++11
LDFLAGS := -lm -lpthread -lOpenCL
endif

SRCS=$(wildcard $(SRC_DIR)/*.cpp)

CCS=$(SRCS:.cpp=.cc)

EXES=$(SRCS:.cpp=)

all: $(EXES)

%: %.cc
	$(COMPILER) $(CPPFLAGS) -o $@ -I../../ $< $(LDFLAGS)

%.cc: %.cpp
	./Reenterable -strict-pre-checks -strict-plc-checks $< $@

clean:
	rm -rf $(CCS)
	rm -rf $(EXES)
