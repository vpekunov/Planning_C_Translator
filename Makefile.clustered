.SUFFIXES:

SRC_DIR := ./Examples/Clustered
LDFLAGS := -lm -lpthread
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
export MPICH_CXX = $(shell ls /opt/homebrew/bin/g++*)
else
export MPICH_CXX = g++
endif
CPPFLAGS := -fopenmp -fgnu-tm -fpermissive -O4 -std=c++11 -I/opt/homebrew/include

SRCS=$(wildcard $(SRC_DIR)/*.cpp)

CCS=$(SRCS:.cpp=.cc)

EXES=$(SRCS:.cpp=)

all: $(EXES)

%: %.cc
	mpic++ $(CPPFLAGS) -o $@ -I../../ $< $(LDFLAGS)

%.cc: %.cpp
	./Reenterable -force-use-mem -strict-pre-checks -strict-plc-checks $< $@

clean:
	rm -rf $(CCS)
	rm -rf $(EXES)
